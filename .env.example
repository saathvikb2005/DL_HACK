# ============================================================
# AI Wellness Companion - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ============================================================

# ── Air Quality API Keys ──
# Get WAQI token from: https://aqicn.org/data-platform/token/
AQI_WAQI_TOKEN=your_waqi_token_here

# Get OpenWeatherMap key from: https://openweathermap.org/api
AQI_OWM_API_KEY=your_openweathermap_api_key_here

# ── Orchestrator Configuration ──
# WAQI token for orchestrator polling (can be same as above)
WAQI_TOKEN=your_waqi_token_here

# Gemini API for dynamic avatar chatbot
# Get key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: model name (examples: gemini-1.5-flash, gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-flash
# Optional: number of recent chat turns included for context
CHAT_HISTORY_TURNS=12

# CORS allowed origins (comma-separated for production)
# Development: http://localhost:5173,http://127.0.0.1:5173
# Production: https://your-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Server Ports (Optional - defaults shown) ──
# ORCHESTRATOR_PORT=8765
# AVATAR_UI_PORT=5173
# WORKPATTERN_PORT=8001
# AIR_QUALITY_PORT=8002
# VIJITHA_PORT=8000

# ── Database (Future Enhancement) ──
# DATABASE_URL=sqlite:///./wellness.db

# ============================================================
# Quick Setup Guide:
# ============================================================
# 1. Copy this file:
#    cp .env.example .env (Linux/Mac)
#    copy .env.example .env (Windows)
#
# 2. Register for free API keys:
#    - WAQI: https://aqicn.org/data-platform/token/
#    - OpenWeatherMap: https://openweathermap.org/api
#
# 3. Replace "your_*_here" with your actual API keys
#
# 4. Keep .env file secure and never share it publicly
# ============================================================
