# ============================================================
# AI Wellness Companion - .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.pnpm-debug.log*

# Environment files (IMPORTANT: Never commit API keys!)
.env
.env.local
.env.*.local
*.env

# Build outputs
build/
dist/
*.bundle.js
.vite/
.cache/

# IDE & Editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS files
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# ML Models (optional - large files)
# Uncomment if you want to exclude trained models from git
# *.pkl
# *.keras
# *.h5
# *.pt
# *.bin

# User-specific data
workpattern/user_profile.json
*.session
*.cache

# Temporary files
*.tmp
temp/
.temp/

# Test files (if any)
*_test.py
test_*.py

# Database files
*.db
*.sqlite
*.sqlite3

# MacOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# Jupyter Notebook
.ipynb_checkpoints

# Documentation builds
docs/_build/
site/
